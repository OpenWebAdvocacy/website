{% extends "layouts/base.njk" %}

{% set postListItems = pagination.items %}

{# If this is a tag, grab those items instead as one large collection #}
{% if tag %}
  {% set postListItems = collections[tag] | reverse | localePostsFilter(page.lang) %}
  {% set content = languages_base[page.lang] %}
  {% set title = content.tagPageTitle1 + (languages_base[page.lang].tags[tag] or tag) + content.tagPageTitle2 %}
{% endif %}

{% block content %}
  <article>
    <h1>{{ title }}</h1>
    {% include "partials/post-list-tag.njk" %}

    {# If we leave pagination in for tags, the next and prev links will
      link to tags and be rather confusing, so don't render in that situation #}
    {% if not tag %}
      {% include "partials/pagination.njk" %}
    {% endif %}
  </article>
{% endblock %}
